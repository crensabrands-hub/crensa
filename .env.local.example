# Environment Configuration
NODE_ENV=development
NEXT_PUBLIC_STAGE=development

# Feature Flags
NEXT_PUBLIC_ENABLE_EARLY_ACCESS=true
NEXT_PUBLIC_SHOW_FOUNDER_BENEFITS=true
NEXT_PUBLIC_ENABLE_TESTIMONIALS=true

# URLs (Development)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Contact Information
NEXT_PUBLIC_SUPPORT_EMAIL=dev@crensa.com

# Social Media Links
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/crensa
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/crensa
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@crensa
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@crensa

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=clerk_api
CLERK_SECRET_KEY=secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Bunny Stream Configuration (Video hosting)
BUNNY_STREAM_LIBRARY_ID=your_library_id
BUNNY_STREAM_API_KEY=your_stream_api_key
BUNNY_STREAM_CDN_HOSTNAME=vz-xxxxxxxx.b-cdn.net

# Bunny Storage Configuration (Thumbnails)
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com
BUNNY_STORAGE_ZONE_NAME=crensa-thumbnails
BUNNY_STORAGE_API_KEY=your_storage_api_key
BUNNY_STORAGE_CDN_HOSTNAME=crensa-thumbnails.b-cdn.net

# Cloudinary Configuration (LEGACY - kept for existing videos only, do not use for new uploads)
CLOUDINARY_CLOUD_NAME=crensa
CLOUDINARY_API_KEY=ApI
CLOUDINARY_API_SECRET=secret_key

# Razorpay Configuration
NEXT_PUBLIC_RAZORPAY_KEY_ID=Api
RAZORPAY_KEY_SECRET=test_1111
RAZORPAY_WEBHOOK_SECRET=test_23435

# Email Configuration (for creator help requests)
ADMIN_EMAIL=admin@crensa.com
ADMIN_EMAIL_USER=your_email@gmail.com
ADMIN_EMAIL_PASS=your_app_password_here

# Alternative: SendGrid Configuration
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# Development Email (for testing)
EMAIL_USER=ethereal.user@ethereal.email
EMAIL_PASS=ethereal.pass

DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require
